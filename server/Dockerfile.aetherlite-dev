# AetherLite — easy-start embedded mode -- preconfigured development version
# Shares all layers with the base aetherlite image
ARG BASE_IMAGE=ghcr.io/scitrera/aetherlite:latest
FROM ${BASE_IMAGE}

# !! DEVELOPMENT ONLY !! Not for production deployment. Hardcodes dev-mode + insecure admin.
ENV AETHER_ALLOW_DEV_MODE=true \
    AETHERLITE_DEV=true \
    AETHERLITE_INSECURE_ADMIN=true

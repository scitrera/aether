package orchestration

import (
	"context"
	"database/sql"
	"fmt"
	"testing"
	"time"

	"github.com/google/uuid"
	taskpg "github.com/scitrera/aether/internal/storage/tasks/postgres"
	"github.com/scitrera/aether/internal/testutil"
)

// TestStaleClaimDetection tests the detectStaleClaims() method
func TestStaleClaimDetection(t *testing.T) {
	testDB, cleanup := testutil.SetupTestDB(t)
	if testDB == nil {
		return // Skip was called in SetupTestDB
	}
	defer testDB.Close()
	defer cleanup()

	ctx := context.Background()

	// Skip test - stale claim detection functionality not yet implemented
	t.Skip("Stale claim detection functionality pending implementation")

	// Create dispatcher instance
	dispatcher, err := NewNotifyTaskDispatcher(
		taskpg.New(testDB.DB),
		"",             // No listener needed for this test
		30*time.Second, // Poll interval
		nil,            // No callback needed
	)
	if err != nil {
		t.Fatalf("Failed to create dispatcher: %v", err)
	}

	t.Run("StaleClaimsDetectedAndUnclaimed", func(t *testing.T) {
		// Clean up test data before this sub-test to ensure isolation
		testDB.DB.Exec("DELETE FROM orchestrated_task_queue WHERE workspace = 'test-workspace'")

		// Create a stale claimed task (claimed 10 minutes ago)
		staleTaskID := uuid.New()
		staleQueueID := uuid.New()

		err := insertOrchestrationTask(testDB.DB, orchestrationTaskParams{
			queueID:            staleQueueID,
			taskID:             staleTaskID,
			targetImpl:         "test-agent",
			workspace:          "test-workspace",
			profile:            "kubernetes",
			status:             "claimed",
			claimedBy:          sql.NullString{String: "orch.test.orch1", Valid: true},
			claimedAtOffset:    sql.NullString{String: "10 minutes", Valid: true}, // 10 minutes ago
		})
		if err != nil {
			t.Fatalf("Failed to insert stale task: %v", err)
		}

		// Get metric value before detection
		metricBefore := dispatcher.GetStaleClaimsDetected()

		// Run stale claim detection
		err = dispatcher.detectStaleClaims(ctx)
		if err != nil {
			t.Errorf("detectStaleClaims() error = %v", err)
		}

		// Verify metric incremented by 1
		metricAfter := dispatcher.GetStaleClaimsDetected()
		if metricAfter != metricBefore+1 {
			t.Errorf("Expected metric to increment by 1 (from %d to %d), got %d", metricBefore, metricBefore+1, metricAfter)
		}

		// Verify task was unclaimed
		var status string
		var claimedBy sql.NullString
		err = testDB.DB.QueryRowContext(ctx,
			"SELECT status, claimed_by FROM orchestrated_task_queue WHERE queue_id = $1",
			staleQueueID,
		).Scan(&status, &claimedBy)
		if err != nil {
			t.Fatalf("Failed to query task status: %v", err)
		}

		if status != "pending" {
			t.Errorf("Expected status 'pending', got '%s'", status)
		}
		if claimedBy.Valid {
			t.Errorf("Expected claimed_by to be NULL, got '%s'", claimedBy.String)
		}
	})

	t.Run("FreshClaimsNotTouched", func(t *testing.T) {
		// Clean up test data before this sub-test to ensure isolation
		testDB.DB.Exec("DELETE FROM orchestrated_task_queue WHERE workspace = 'test-workspace'")

		// Create a fresh claimed task (claimed 2 minutes ago)
		freshTaskID := uuid.New()
		freshQueueID := uuid.New()

		err := insertOrchestrationTask(testDB.DB, orchestrationTaskParams{
			queueID:            freshQueueID,
			taskID:             freshTaskID,
			targetImpl:         "test-agent",
			workspace:          "test-workspace",
			profile:            "kubernetes",
			status:             "claimed",
			claimedBy:          sql.NullString{String: "orch.test.orch2", Valid: true},
			claimedAtOffset:    sql.NullString{String: "2 minutes", Valid: true}, // 2 minutes ago (fresh)
		})
		if err != nil {
			t.Fatalf("Failed to insert fresh task: %v", err)
		}

		// Get metric value before detection
		metricBefore := dispatcher.GetStaleClaimsDetected()

		// Run stale claim detection
		err = dispatcher.detectStaleClaims(ctx)
		if err != nil {
			t.Errorf("detectStaleClaims() error = %v", err)
		}

		// Verify metric did not increment (no stale claims)
		metricAfter := dispatcher.GetStaleClaimsDetected()
		if metricAfter != metricBefore {
			t.Errorf("Expected metric to remain at %d, got %d", metricBefore, metricAfter)
		}

		// Verify task is still claimed
		var status string
		var claimedBy sql.NullString
		err = testDB.DB.QueryRowContext(ctx,
			"SELECT status, claimed_by FROM orchestrated_task_queue WHERE queue_id = $1",
			freshQueueID,
		).Scan(&status, &claimedBy)
		if err != nil {
			t.Fatalf("Failed to query task status: %v", err)
		}

		if status != "claimed" {
			t.Errorf("Expected status 'claimed', got '%s'", status)
		}
		if !claimedBy.Valid || claimedBy.String != "orch.test.orch2" {
			t.Errorf("Expected claimed_by 'orch.test.orch2', got '%v'", claimedBy)
		}
	})

	t.Run("CompletedAndFailedClaimsIgnored", func(t *testing.T) {
		// Clean up test data before this sub-test to ensure isolation
		testDB.DB.Exec("DELETE FROM orchestrated_task_queue WHERE workspace = 'test-workspace'")

		// Create completed task with old claimed_at
		completedTaskID := uuid.New()
		completedQueueID := uuid.New()

		err := insertOrchestrationTask(testDB.DB, orchestrationTaskParams{
			queueID:            completedQueueID,
			taskID:             completedTaskID,
			targetImpl:         "test-agent",
			workspace:          "test-workspace",
			profile:            "kubernetes",
			status:             "completed",
			claimedBy:          sql.NullString{String: "orch.test.orch3", Valid: true},
			claimedAtOffset:    sql.NullString{String: "10 minutes", Valid: true},
		})
		if err != nil {
			t.Fatalf("Failed to insert completed task: %v", err)
		}

		// Create failed task with old claimed_at
		failedTaskID := uuid.New()
		failedQueueID := uuid.New()

		err = insertOrchestrationTask(testDB.DB, orchestrationTaskParams{
			queueID:            failedQueueID,
			taskID:             failedTaskID,
			targetImpl:         "test-agent",
			workspace:          "test-workspace",
			profile:            "kubernetes",
			status:             "failed",
			claimedBy:          sql.NullString{String: "orch.test.orch4", Valid: true},
			claimedAtOffset:    sql.NullString{String: "10 minutes", Valid: true},
		})
		if err != nil {
			t.Fatalf("Failed to insert failed task: %v", err)
		}

		// Run stale claim detection
		err = dispatcher.detectStaleClaims(ctx)
		if err != nil {
			t.Errorf("detectStaleClaims() error = %v", err)
		}

		// Verify completed task status unchanged
		var completedStatus string
		err = testDB.DB.QueryRowContext(ctx,
			"SELECT status FROM orchestrated_task_queue WHERE queue_id = $1",
			completedQueueID,
		).Scan(&completedStatus)
		if err != nil {
			t.Fatalf("Failed to query completed task: %v", err)
		}
		if completedStatus != "completed" {
			t.Errorf("Completed task status changed to '%s'", completedStatus)
		}

		// Verify failed task status unchanged
		var failedStatus string
		err = testDB.DB.QueryRowContext(ctx,
			"SELECT status FROM orchestrated_task_queue WHERE queue_id = $1",
			failedQueueID,
		).Scan(&failedStatus)
		if err != nil {
			t.Fatalf("Failed to query failed task: %v", err)
		}
		if failedStatus != "failed" {
			t.Errorf("Failed task status changed to '%s'", failedStatus)
		}
	})

	t.Run("MultipleStaleClaims", func(t *testing.T) {
		// Clean up test data before this sub-test to ensure isolation
		testDB.DB.Exec("DELETE FROM orchestrated_task_queue WHERE workspace = 'test-workspace'")

		// Create multiple stale tasks
		staleCount := 3
		staleQueueIDs := make([]uuid.UUID, staleCount)

		for i := 0; i < staleCount; i++ {
			taskID := uuid.New()
			queueID := uuid.New()
			staleQueueIDs[i] = queueID

			err := insertOrchestrationTask(testDB.DB, orchestrationTaskParams{
				queueID:            queueID,
				taskID:             taskID,
				targetImpl:         "test-agent",
				workspace:          "test-workspace",
				profile:            "kubernetes",
				status:             "claimed",
				claimedBy:          sql.NullString{String: "orch.test.batch", Valid: true},
				claimedAtOffset:    sql.NullString{String: "10 minutes", Valid: true},
			})
			if err != nil {
				t.Fatalf("Failed to insert stale task %d: %v", i, err)
			}
		}

		// Get metric value before detection
		metricBefore := dispatcher.GetStaleClaimsDetected()

		// Run stale claim detection
		err = dispatcher.detectStaleClaims(ctx)
		if err != nil {
			t.Errorf("detectStaleClaims() error = %v", err)
		}

		// Verify metric incremented by staleCount
		metricAfter := dispatcher.GetStaleClaimsDetected()
		expectedMetric := metricBefore + uint64(staleCount)
		if metricAfter != expectedMetric {
			t.Errorf("Expected metric to increment by %d (from %d to %d), got %d", staleCount, metricBefore, expectedMetric, metricAfter)
		}

		// Verify all tasks were unclaimed
		for i, queueID := range staleQueueIDs {
			var status string
			err = testDB.DB.QueryRowContext(ctx,
				"SELECT status FROM orchestrated_task_queue WHERE queue_id = $1",
				queueID,
			).Scan(&status)
			if err != nil {
				t.Fatalf("Failed to query task %d: %v", i, err)
			}
			if status != "pending" {
				t.Errorf("Task %d: expected status 'pending', got '%s'", i, status)
			}
		}
	})

	t.Run("PendingTasksNotAffected", func(t *testing.T) {
		// Clean up test data before this sub-test to ensure isolation
		testDB.DB.Exec("DELETE FROM orchestrated_task_queue WHERE workspace = 'test-workspace'")

		// Create a pending task (never claimed)
		pendingTaskID := uuid.New()
		pendingQueueID := uuid.New()

		err := insertOrchestrationTask(testDB.DB, orchestrationTaskParams{
			queueID:    pendingQueueID,
			taskID:     pendingTaskID,
			targetImpl: "test-agent",
			workspace:  "test-workspace",
			profile:    "kubernetes",
			status:     "pending",
			claimedBy:  sql.NullString{Valid: false}, // NULL
		})
		if err != nil {
			t.Fatalf("Failed to insert pending task: %v", err)
		}

		// Run stale claim detection
		err = dispatcher.detectStaleClaims(ctx)
		if err != nil {
			t.Errorf("detectStaleClaims() error = %v", err)
		}

		// Verify task is still pending
		var status string
		err = testDB.DB.QueryRowContext(ctx,
			"SELECT status FROM orchestrated_task_queue WHERE queue_id = $1",
			pendingQueueID,
		).Scan(&status)
		if err != nil {
			t.Fatalf("Failed to query task status: %v", err)
		}

		if status != "pending" {
			t.Errorf("Expected status 'pending', got '%s'", status)
		}
	})
}

// orchestrationTaskParams holds parameters for test task insertion
type orchestrationTaskParams struct {
	queueID         uuid.UUID
	taskID          uuid.UUID
	targetImpl      string
	workspace       string
	profile         string
	status          string
	claimedBy       sql.NullString
	claimedAtOffset sql.NullString // e.g., "10 minutes" for NOW() - INTERVAL '10 minutes'
}

// insertOrchestrationTask is a test helper to insert tasks into orchestrated_task_queue
func insertOrchestrationTask(db *sql.DB, params orchestrationTaskParams) error {
	var query string
	var args []interface{}

	if params.claimedAtOffset.Valid {
		// Insert with claimed_at in the past
		query = `
			INSERT INTO orchestrated_task_queue
			(queue_id, task_id, target_implementation, workspace, profile, status, claimed_by, claimed_at)
			VALUES ($1, $2, $3, $4, $5, $6, $7, NOW() - INTERVAL '1 minute' * $8)
		`
		// Convert offset string like "10 minutes" to just the number
		var minutes int
		if _, err := fmt.Sscanf(params.claimedAtOffset.String, "%d", &minutes); err != nil {
			return fmt.Errorf("invalid claimedAtOffset format: %v", err)
		}
		args = []interface{}{
			params.queueID,
			params.taskID,
			params.targetImpl,
			params.workspace,
			params.profile,
			params.status,
			params.claimedBy,
			minutes,
		}
	} else {
		// Insert without claimed_at
		query = `
			INSERT INTO orchestrated_task_queue
			(queue_id, task_id, target_implementation, workspace, profile, status, claimed_by)
			VALUES ($1, $2, $3, $4, $5, $6, $7)
		`
		args = []interface{}{
			params.queueID,
			params.taskID,
			params.targetImpl,
			params.workspace,
			params.profile,
			params.status,
			params.claimedBy,
		}
	}

	_, err := db.Exec(query, args...)
	return err
}
